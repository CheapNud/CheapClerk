@inherits LayoutComponentBase
@using CheapClerk.Web.Theme

<MudThemeProvider Theme="ClerkTheme.Instance" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Dense="true" Style="border-bottom: 1px solid rgba(255,255,255,0.05);">
        <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@(() => _drawerOpen = !_drawerOpen)" />
        <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Primary" Class="ml-2" />
        <MudText Typo="Typo.h6" Class="ml-1" Style="font-weight: 700; letter-spacing: 1px;">CHEAPCLERK</MudText>
        <MudSpacer />
        <MudTooltip Text="Toggle Dark Mode">
            <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit"
                           OnClick="@(() => _isDarkMode = !_isDarkMode)" />
        </MudTooltip>
    </MudAppBar>

    <MudDrawer @bind-Open="_drawerOpen" Elevation="0" Variant="DrawerVariant.Mini" OpenMiniOnHover="true"
               Style="border-right: 1px solid rgba(255,255,255,0.05);">
        <MudDrawerHeader Dense="true" Class="d-flex align-center">
            <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Primary" />
            <MudText Typo="Typo.body1" Class="ml-2" Style="font-weight: 600;">Clerk</MudText>
        </MudDrawerHeader>
        <MudNavMenu Bordered="true" Color="Color.Primary">
            <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">Dashboard</MudNavLink>
            <MudNavLink Href="/documents" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.FolderOpen">Documents</MudNavLink>
            <MudNavLink Href="/search" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Search">Search</MudNavLink>
            <MudNavLink Href="/tags" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Label">Tags</MudNavLink>
            <MudNavLink Href="/expiring" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Schedule">Expiring</MudNavLink>
        </MudNavMenu>
    </MudDrawer>

    <MudMainContent Class="pt-14 px-4 pb-4" Style="min-height: 100vh;">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = true;
}
