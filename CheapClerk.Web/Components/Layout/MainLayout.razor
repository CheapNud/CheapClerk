@inherits LayoutComponentBase
@using CheapClerk.Web.Theme

<MudThemeProvider Theme="ClerkTheme.Instance" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="0" Dense="true" Style="border-bottom: 1px solid rgba(255,255,255,0.05);">
        <AuthorizeView>
            <Authorized>
                <MudIconButton Icon="@Icons.Material.Filled.Menu" Color="Color.Inherit" Edge="Edge.Start" OnClick="@(() => _drawerOpen = !_drawerOpen)" />
            </Authorized>
        </AuthorizeView>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                <MudTooltip Text="@Loc["Upload"]">
                    <MudIconButton Icon="@Icons.Material.Filled.UploadFile" Color="Color.Inherit" OnClick="OpenUploadDialogAsync" />
                </MudTooltip>
            </Authorized>
        </AuthorizeView>
        <MudIcon Icon="@Icons.Material.Filled.Language" Color="Color.Inherit" Class="mr-1" Size="Size.Small" />
        <MudLink Href="@($"/culture/set?culture=en&redirectUri={Uri.EscapeDataString(CurrentPath)}")"
                 Color="Color.Inherit" Underline="Underline.None" Class="mx-1"
                 data-enhance-nav="false">English</MudLink>
        <MudLink Href="@($"/culture/set?culture=nl&redirectUri={Uri.EscapeDataString(CurrentPath)}")"
                 Color="Color.Inherit" Underline="Underline.None" Class="mr-2"
                 data-enhance-nav="false">Nederlands</MudLink>
        <MudTooltip Text="@Loc["ToggleDarkMode"]">
            <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit"
                           OnClick="@(() => _isDarkMode = !_isDarkMode)" />
        </MudTooltip>
        <AuthorizeView>
            <Authorized>
                <MudText Typo="Typo.body2" Class="ml-3" Style="opacity: 0.7;">@context.User.Identity?.Name</MudText>
                <MudTooltip Text="@Loc["SignOut"]">
                    <MudIconButton Href="/auth/logout" Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit"
                                   Class="ml-1" data-enhance-nav="false" />
                </MudTooltip>
            </Authorized>
        </AuthorizeView>
    </MudAppBar>

    <AuthorizeView>
        <Authorized>
            <MudDrawer @bind-Open="_drawerOpen" Elevation="0" Variant="DrawerVariant.Mini" OpenMiniOnHover="true"
                       Style="border-right: 1px solid rgba(255,255,255,0.05);">
                <MudDrawerHeader Dense="true" Class="d-flex align-center">
                    <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Primary" />
                    <MudText Typo="Typo.body1" Class="ml-2" Style="font-weight: 600; letter-spacing: 1px;">CHEAPCLERK</MudText>
                </MudDrawerHeader>
                <MudNavMenu Bordered="true" Color="Color.Primary">
                    <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">@Loc["Dashboard"]</MudNavLink>
                    <MudNavLink Href="/documents" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.FolderOpen">@Loc["Documents"]</MudNavLink>
                    <MudNavLink Href="/tags" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Label">@Loc["Tags"]</MudNavLink>
                    <MudNavLink Href="/expiring" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Schedule">@Loc["Expiring"]</MudNavLink>
                    <MudNavLink Href="/review" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.RateReview">
                @Loc["Review"]
                @if (_reviewCount > 0)
                {
                    <MudChip T="string" Size="Size.Small" Color="Color.Warning" Variant="Variant.Filled" Class="ml-2">@_reviewCount</MudChip>
                }
            </MudNavLink>
                </MudNavMenu>
                <MudSpacer />
                <MudText Typo="Typo.caption" Class="pa-3" Style="opacity: 0.2;">@CheapClerk.AppVersion.Display</MudText>
            </MudDrawer>
        </Authorized>
    </AuthorizeView>

    <MudMainContent Class="pt-14 px-4 pb-4" Style="min-height: 100vh;">
        @Body
    </MudMainContent>
</MudLayout>

@code {
    [Inject] private IStringLocalizer<SharedResources> Loc { get; set; } = null!;
    [Inject] private NavigationManager Navigation { get; set; } = null!;
    [Inject] private IDialogService DialogService { get; set; } = null!;
    [Inject] private CheapClerk.Services.ReviewQueueService ReviewQueue { get; set; } = null!;

    [CascadingParameter] private Task<AuthenticationState>? AuthState { get; set; }

    private bool _drawerOpen = true;
    private bool _isDarkMode = true;
    private int _reviewCount;

    protected override async Task OnInitializedAsync()
    {
        if (AuthState is null) return;
        var auth = await AuthState;
        if (auth.User.Identity?.IsAuthenticated != true) return;

        try
        {
            // Once per circuit is enough for a hint badge; the page itself is live
            _reviewCount = (await ReviewQueue.GetQueueAsync()).Count;
        }
        catch
        {
            // A dead Paperless must not break the layout — badge just stays hidden
        }
    }

    // The culture endpoint only accepts app-local paths, never absolute URIs
    private string CurrentPath => new Uri(Navigation.Uri).PathAndQuery;

    private async Task OpenUploadDialogAsync() =>
        // Backdrop/escape dismissal would bypass the dialog's busy guard mid-upload
        await DialogService.ShowAsync<UploadDialog>(Loc["UploadDocuments"],
            new DialogOptions { BackdropClick = false, CloseOnEscapeKey = false });
}
