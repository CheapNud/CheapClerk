@page "/"
@using CheapClerk.Configuration
@using Microsoft.Extensions.Options

<PageTitle>CheapClerk — Dashboard</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">Dashboard</MudText>
<MudText Typo="Typo.body1" Class="mb-6" Style="opacity: 0.6;">Your household documents at a glance.</MudText>

<MudGrid>
    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="0" Style="border: 1px solid rgba(255,255,255,0.06);">
            <MudCardContent Class="d-flex align-center gap-4">
                <MudIcon Icon="@Icons.Material.Filled.Description" Color="Color.Primary" Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.h4">@_documentCount</MudText>
                    <MudText Typo="Typo.body2" Style="opacity: 0.6;">Documents</MudText>
                </div>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="0" Style="border: 1px solid rgba(255,255,255,0.06);">
            <MudCardContent Class="d-flex align-center gap-4">
                <MudIcon Icon="@Icons.Material.Filled.Label" Color="Color.Secondary" Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.h4">@_tagCount</MudText>
                    <MudText Typo="Typo.body2" Style="opacity: 0.6;">Tags</MudText>
                </div>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="0" Style="border: 1px solid rgba(255,255,255,0.06);">
            <MudCardContent Class="d-flex align-center gap-4">
                <MudIcon Icon="@Icons.Material.Filled.People" Color="Color.Tertiary" Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.h4">@_correspondentCount</MudText>
                    <MudText Typo="Typo.body2" Style="opacity: 0.6;">Correspondents</MudText>
                </div>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="0" Style="@($"border: 1px solid {(_expiringCount > 0 ? "rgba(255,87,34,0.5)" : "rgba(255,255,255,0.06)")};")">
            <MudCardContent Class="d-flex align-center gap-4">
                <MudIcon Icon="@Icons.Material.Filled.Schedule"
                         Color="@(_expiringCount > 0 ? Color.Warning : Color.Default)"
                         Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.h4">@_expiringCount</MudText>
                    <MudLink Href="/expiring" Typo="Typo.body2" Style="opacity: 0.6;">Expiring in 30 days</MudLink>
                </div>
            </MudCardContent>
        </MudCard>
    </MudItem>
    <MudItem xs="12" sm="6" md="4">
        <MudCard Elevation="0" Style="@($"border: 1px solid {(_inboxCount > 0 ? "rgba(33,150,243,0.5)" : "rgba(255,255,255,0.06)")};")">
            <MudCardContent Class="d-flex align-center gap-4">
                <MudIcon Icon="@Icons.Material.Filled.MoveToInbox"
                         Color="@(_inboxCount > 0 ? Color.Info : Color.Default)" Size="Size.Large" />
                <div>
                    <MudText Typo="Typo.h4">@_inboxCount</MudText>
                    <MudText Typo="Typo.body2" Style="opacity: 0.6;">In inbox</MudText>
                </div>
                <MudSpacer />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                           Disabled="@(_inboxCount == 0 || _processing)"
                           OnClick="@(() => ProcessInboxAsync())">
                    @(_processing ? "Processing..." : "Process now")
                </MudButton>
            </MudCardContent>
        </MudCard>
    </MudItem>
</MudGrid>

<MudText Typo="Typo.h5" Class="mt-8 mb-4">Recently Added</MudText>

@if (_recentDocuments is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_recentDocuments.Count == 0)
{
    <MudAlert Severity="Severity.Info">No documents found. Start scanning!</MudAlert>
}
else
{
    <MudTable Items="_recentDocuments" Hover="true" Elevation="0" Dense="true"
              Style="border: 1px solid rgba(255,255,255,0.06);">
        <HeaderContent>
            <MudTh>ID</MudTh>
            <MudTh>Title</MudTh>
            <MudTh>Added</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.Id</MudTd>
            <MudTd>
                <MudLink Href="@($"/documents/{context.Id}")">@context.Title</MudLink>
            </MudTd>
            <MudTd>@(context.Added?.ToString("yyyy-MM-dd") ?? "—")</MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    [Inject] private PaperlessClient PaperlessClient { get; set; } = null!;
    [Inject] private ExtractionCacheService ExtractionCache { get; set; } = null!;
    [Inject] private InboxProcessorService InboxProcessor { get; set; } = null!;
    [Inject] private IOptions<ClassificationOptions> ClassificationConfig { get; set; } = null!;
    [Inject] private ISnackbar Snackbar { get; set; } = null!;

    private List<PaperlessDocument>? _recentDocuments;
    private int _documentCount;
    private int _tagCount;
    private int _correspondentCount;
    private int _expiringCount;
    private int _inboxCount;
    private bool _processing;

    protected override async Task OnInitializedAsync()
    {
        var docsTask = PaperlessClient.ListDocumentsAsync(maxResults: 10);
        var tagsTask = PaperlessClient.GetTagsAsync();
        var corrsTask = PaperlessClient.GetCorrespondentsAsync();
        var expiringTask = ExtractionCache.FindExpiringAsync(30);

        await Task.WhenAll(docsTask, tagsTask, corrsTask, expiringTask);

        _recentDocuments = await docsTask;
        var tags = await tagsTask;
        var correspondents = await corrsTask;
        var expiring = await expiringTask;

        _documentCount = _recentDocuments.Count;
        _tagCount = tags.Count;
        _correspondentCount = correspondents.Count;
        _expiringCount = expiring.Count;

        await LoadInboxCountAsync();
    }

    private async Task ProcessInboxAsync()
    {
        if (_processing) return;
        _processing = true;
        try
        {
            var report = await InboxProcessor.ProcessInboxAsync();
            if (report.SkippedReason is not null)
            {
                Snackbar.Add($"Inbox processing skipped: {report.SkippedReason}", Severity.Warning);
            }
            else
            {
                var applied = report.Outcomes.Count(o => o.Applied);
                var review = report.Outcomes.Count(o => o.SentToReview);
                var failed = report.Outcomes.Count(o => o.Error is not null);
                var severity = failed > 0
                    ? Severity.Error
                    : review > 0 ? Severity.Warning : Severity.Success;
                Snackbar.Add($"Inbox processed: {applied} filed, {review} sent to review, {failed} failed.", severity);
            }
            await LoadInboxCountAsync();
        }
        finally
        {
            _processing = false;
        }
    }

    private async Task LoadInboxCountAsync()
    {
        var tags = await PaperlessClient.GetTagsAsync();
        var inboxTag = tags.FirstOrDefault(t =>
            t.Name.Equals(ClassificationConfig.Value.InboxTagName, StringComparison.OrdinalIgnoreCase));
        _inboxCount = inboxTag?.DocumentCount ?? 0;
    }
}
