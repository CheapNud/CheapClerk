@page "/tags"
@using System.Globalization
@inject IStringLocalizer<SharedResources> Loc
@inject TaxonomyTranslationService Taxonomy

<PageTitle>@Loc["AppTagsTitle"]</PageTitle>

<MudText Typo="Typo.h4" GutterBottom="true">@Loc["Tags"]</MudText>

@if (_tags is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_tags.Count == 0)
{
    <MudAlert Severity="Severity.Info">@Loc["NoTagsFoundInPaperless"]</MudAlert>
}
else
{
    <MudTable Items="@_tags.OrderByDescending(t => t.DocumentCount)" Hover="true" Elevation="0" Dense="true"
              Style="border: 1px solid rgba(255,255,255,0.06);">
        <HeaderContent>
            <MudTh>@Loc["Tag"]</MudTh>
            <MudTh>@Loc["Documents"]</MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>
                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary">@TagLabel(context.Name)</MudChip>
                @if (!string.Equals(TagLabel(context.Name), context.Name, StringComparison.Ordinal))
                {
                    <MudText Typo="Typo.caption" Class="ml-2" Style="opacity: 0.6;">@context.Name</MudText>
                }
            </MudTd>
            <MudTd>@context.DocumentCount</MudTd>
        </RowTemplate>
    </MudTable>
}

@code {
    [Inject] private PaperlessClient PaperlessClient { get; set; } = null!;

    private List<PaperlessTag>? _tags;
    private Dictionary<string, string> _tagLabels = new(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnInitializedAsync()
    {
        _tags = await PaperlessClient.GetTagsAsync();
        _tagLabels = await Taxonomy.GetDisplayMapAsync("tag", CultureInfo.CurrentUICulture.TwoLetterISOLanguageName);
    }

    private string TagLabel(string canonical) => _tagLabels.TryGetValue(canonical, out var label) ? label : canonical;
}
