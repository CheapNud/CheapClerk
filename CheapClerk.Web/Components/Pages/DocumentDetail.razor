@page "/documents/{DocumentId:int}"
@using CheapClerk.Models.Classification
@using CheapClerk.Models.Extraction
@using CheapClerk.Services
@using CheapClerk.Web.Services
@using System.Globalization
@inject IStringLocalizer<SharedResources> Loc
@inject TaxonomyTranslationService Taxonomy

<PageTitle>@Loc["AppDocumentDetailTitle", DocumentId]</PageTitle>

@if (_doc is null && !_notFound)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_notFound)
{
    <MudAlert Severity="Severity.Warning">@Loc["DocumentNotFound", DocumentId]</MudAlert>
}
else
{
    <MudText Typo="Typo.h4" GutterBottom="true">@_doc!.Title</MudText>

    <MudGrid>
        <MudItem xs="12" md="4">
            <MudCard Elevation="0" Style="border: 1px solid rgba(255,255,255,0.06);">
                <MudCardContent>
                    <div class="d-flex align-center justify-space-between mb-2">
                        <MudText Typo="Typo.h6">@Loc["Metadata"]</MudText>
                        @if (!_isEditing)
                        {
                            <div>
                                <MudIconButton Icon="@Icons.Material.Filled.Edit" Size="Size.Small"
                                               OnClick="@(() => _isEditing = true)" title="@Loc["Edit"]" />
                                <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" Color="Color.Error"
                                               OnClick="DeleteAsync" Disabled="_isSaving" title="@Loc["Delete"]" />
                            </div>
                        }
                    </div>

                    @if (_isEditing)
                    {
                        <MudStack Spacing="3">
                            <MudTextField T="string" @bind-Value="_editTitle" Label="@Loc["Title"]" Variant="Variant.Outlined" />
                            <MudTextField T="string" @bind-Value="_editCorrespondent" Label="@Loc["Correspondent"]" Variant="Variant.Outlined" />
                            <MudTextField T="string" @bind-Value="_editDocumentType" Label="@Loc["Type"]" Variant="Variant.Outlined" />
                            <MudTextField T="string" @bind-Value="_editTagsCsv" Label="@Loc["TagsCommaSeparated"]" Variant="Variant.Outlined" />
                            <div>
                                <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                           OnClick="SaveEditAsync" Disabled="_isSaving">@Loc["Save"]</MudButton>
                                <MudButton Variant="Variant.Text" Size="Size.Small" Class="ml-2"
                                           OnClick="@(() => _isEditing = false)" Disabled="_isSaving">@Loc["Cancel"]</MudButton>
                            </div>
                        </MudStack>
                    }
                    else
                    {
                    <MudSimpleTable Dense="true" Elevation="0">
                        <tbody>
                            <tr><td><strong>@Loc["DocumentIdLabel"]</strong></td><td>@_doc!.Id</td></tr>
                            @if (_correspondentName is not null)
                            {
                                <tr><td><strong>@Loc["Correspondent"]</strong></td><td>@_correspondentName</td></tr>
                            }
                            @if (_documentTypeName is not null)
                            {
                                <tr><td><strong>@Loc["Type"]</strong></td><td>@_documentTypeName</td></tr>
                            }
                            @if (_doc.Created.HasValue)
                            {
                                <tr><td><strong>@Loc["Created"]</strong></td><td>@_doc.Created.Value.ToString("yyyy-MM-dd")</td></tr>
                            }
                            @if (_doc.Added.HasValue)
                            {
                                <tr><td><strong>@Loc["Added"]</strong></td><td>@_doc.Added.Value.ToString("yyyy-MM-dd")</td></tr>
                            }
                            @if (_doc.OriginalFileName is not null)
                            {
                                <tr><td><strong>@Loc["OriginalFile"]</strong></td><td>@_doc.OriginalFileName</td></tr>
                            }
                            @if (_doc.ArchiveSerialNumber.HasValue)
                            {
                                <tr><td><strong>@Loc["Asn"]</strong></td><td>@_doc.ArchiveSerialNumber</td></tr>
                            }
                        </tbody>
                    </MudSimpleTable>

                    @if (_tagNames.Count > 0)
                    {
                        <MudText Typo="Typo.subtitle2" Class="mt-4 mb-2">@Loc["Tags"]</MudText>
                        @foreach (var tagName in _tagNames)
                        {
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary" Class="mr-1 mb-1">@TagLabel(tagName)</MudChip>
                        }
                    }
                    }
                </MudCardContent>
            </MudCard>

            <MudCard Elevation="0" Class="mt-4" Style="border: 1px solid rgba(255,255,255,0.06);">
                <MudCardContent>
                    <MudText Typo="Typo.h6" GutterBottom="true">@Loc["Classification"]</MudText>

                    @if (_suggestion?.Classification is { } parked)
                    {
                        <MudText Typo="Typo.caption" Style="opacity: 0.6;">@Loc["ClerkSuggestion"] — @Loc["ConfidencePercent", $"{_suggestion.Value.Confidence:P0}"]</MudText>
                        <MudSimpleTable Dense="true" Elevation="0" Class="mt-1 mb-3">
                            <tbody>
                                @if (!string.IsNullOrWhiteSpace(parked.SuggestedTitle)) { <tr><td><strong>@Loc["Title"]</strong></td><td>@parked.SuggestedTitle</td></tr> }
                                @if (!string.IsNullOrWhiteSpace(parked.Correspondent)) { <tr><td><strong>@Loc["Correspondent"]</strong></td><td>@parked.Correspondent</td></tr> }
                                @if (!string.IsNullOrWhiteSpace(parked.DocumentType)) { <tr><td><strong>@Loc["Type"]</strong></td><td>@parked.DocumentType</td></tr> }
                                @if (parked.Tags.Count > 0) { <tr><td><strong>@Loc["Tags"]</strong></td><td>@string.Join(", ", parked.Tags)</td></tr> }
                                @if (!string.IsNullOrWhiteSpace(parked.DocumentDate)) { <tr><td><strong>@Loc["Date"]</strong></td><td>@parked.DocumentDate</td></tr> }
                            </tbody>
                        </MudSimpleTable>
                        <div class="d-flex flex-wrap gap-2 mb-2">
                            <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                                       OnClick="ApplySuggestionAsync" Disabled="@(_isSaving || _isRerunning)">@Loc["Accept"]</MudButton>
                            <MudButton Variant="Variant.Outlined" Size="Size.Small"
                                       OnClick="EditFromSuggestion" Disabled="@(_isSaving || _isRerunning)">@Loc["Edit"]</MudButton>
                        </div>
                    }

                    <div class="d-flex align-center flex-wrap gap-2">
                        <MudButton Variant="Variant.Outlined" Color="Color.Secondary" Size="Size.Small"
                                   OnClick="RerunClassificationAsync" Disabled="@(_isSaving || _isRerunning)"
                                   StartIcon="@Icons.Material.Filled.Autorenew">
                            @(_isRerunning ? Loc["Analyzing"] : Loc["Rerun"])
                        </MudButton>
                        <MudSwitch T="bool" @bind-Value="_forceVision" Size="Size.Small" Label="@Loc["ForceVisionOcrOnRerun"]" />
                    </div>
                </MudCardContent>
            </MudCard>

            <MudCard Elevation="0" Class="mt-4" Style="border: 1px solid rgba(255,255,255,0.06);">
                <MudCardContent>
                    <div class="d-flex align-center justify-space-between mb-3">
                        <MudText Typo="Typo.h6">@Loc["ExtractedData"]</MudText>
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Tertiary"
                                   OnClick="RunExtractionAsync" Disabled="_isExtracting"
                                   StartIcon="@Icons.Material.Filled.AutoAwesome">
                            @(_isExtracting ? Loc["Extracting"] : Loc["Extract"])
                        </MudButton>
                    </div>

                    @if (_isExtracting)
                    {
                        <MudProgressLinear Indeterminate="true" Color="Color.Tertiary" />
                    }
                    else if (_extracted is null)
                    {
                        <MudText Typo="Typo.body2" Style="opacity: 0.5;">@Loc["ClickExtractToClassify"]</MudText>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Tertiary" Class="mb-2">
                            @_extracted.Category
                        </MudChip>
                        <MudText Typo="Typo.caption" Class="ml-2" Style="opacity: 0.6;">
                            @Loc["ConfidencePercent", $"{_extracted.Confidence:P0}"]
                        </MudText>

                        @if (_extracted.Summary is not null)
                        {
                            <MudText Typo="Typo.body2" Class="mt-2 mb-3" Style="font-style: italic; opacity: 0.8;">
                                @_extracted.Summary
                            </MudText>
                        }

                        @if (_extracted.Invoice is not null)
                        {
                            <MudSimpleTable Dense="true" Elevation="0">
                                <tbody>
                                    @if (_extracted.Invoice.Vendor is not null) { <tr><td><strong>@Loc["Vendor"]</strong></td><td>@_extracted.Invoice.Vendor</td></tr> }
                                    @if (_extracted.Invoice.InvoiceNumber is not null) { <tr><td><strong>@Loc["InvoiceNumber"]</strong></td><td>@_extracted.Invoice.InvoiceNumber</td></tr> }
                                    @if (_extracted.Invoice.TotalAmount.HasValue) { <tr><td><strong>@Loc["Total"]</strong></td><td>@_extracted.Invoice.TotalAmount @_extracted.Invoice.Currency</td></tr> }
                                    @if (_extracted.Invoice.IssueDate is not null) { <tr><td><strong>@Loc["Issued"]</strong></td><td>@_extracted.Invoice.IssueDate</td></tr> }
                                    @if (_extracted.Invoice.DueDate is not null) { <tr><td><strong>@Loc["Due"]</strong></td><td>@_extracted.Invoice.DueDate</td></tr> }
                                    @if (_extracted.Invoice.AccountNumber is not null) { <tr><td><strong>@Loc["Account"]</strong></td><td>@_extracted.Invoice.AccountNumber</td></tr> }
                                    @if (_extracted.Invoice.PaymentReference is not null) { <tr><td><strong>@Loc["Reference"]</strong></td><td>@_extracted.Invoice.PaymentReference</td></tr> }
                                    @if (_extracted.Invoice.BeneficiaryIban is not null) { <tr><td><strong>@Loc["Iban"]</strong></td><td>@_extracted.Invoice.BeneficiaryIban</td></tr> }
                                </tbody>
                            </MudSimpleTable>

                            @if (_paymentQr is not null)
                            {
                                <MudText Typo="Typo.subtitle2" Class="mt-4 mb-2">@Loc["PayThisBill"]</MudText>
                                <MudImage Src="@_paymentQr" Width="200" Class="rounded mb-2" />

                                <MudSimpleTable Dense="true" Elevation="0">
                                    <tbody>
                                        <tr><td><strong>@Loc["PaymentBeneficiary"]</strong></td><td>@(_extracted.Invoice.Vendor ?? _correspondentName)</td></tr>
                                        <tr><td><strong>@Loc["PaymentIban"]</strong></td><td>@(_paymentPayload!.Split('\n')[6])</td></tr>
                                        <tr><td><strong>@Loc["PaymentAmount"]</strong></td><td>@_extracted.Invoice.TotalAmount @_extracted.Invoice.Currency</td></tr>
                                        <tr><td><strong>@Loc["PaymentReference"]</strong></td><td>@(_extracted.Invoice.PaymentReference ?? _extracted.Invoice.InvoiceNumber)</td></tr>
                                    </tbody>
                                </MudSimpleTable>

                                <MudText Typo="Typo.caption" Class="mt-2" Style="opacity: 0.6;">@Loc["PaymentVerifyCaution"]</MudText>
                            }
                        }
                        else if (_extracted.Insurance is not null)
                        {
                            <MudSimpleTable Dense="true" Elevation="0">
                                <tbody>
                                    @if (_extracted.Insurance.Insurer is not null) { <tr><td><strong>@Loc["Insurer"]</strong></td><td>@_extracted.Insurance.Insurer</td></tr> }
                                    @if (_extracted.Insurance.PolicyNumber is not null) { <tr><td><strong>@Loc["PolicyNumber"]</strong></td><td>@_extracted.Insurance.PolicyNumber</td></tr> }
                                    @if (_extracted.Insurance.PolicyType is not null) { <tr><td><strong>@Loc["Type"]</strong></td><td>@_extracted.Insurance.PolicyType</td></tr> }
                                    @if (_extracted.Insurance.PremiumAmount.HasValue) { <tr><td><strong>@Loc["Premium"]</strong></td><td>@_extracted.Insurance.PremiumAmount (@_extracted.Insurance.PremiumFrequency)</td></tr> }
                                    @if (_extracted.Insurance.Deductible.HasValue) { <tr><td><strong>@Loc["Deductible"]</strong></td><td>@_extracted.Insurance.Deductible</td></tr> }
                                    @if (_extracted.Insurance.CoverageStart is not null) { <tr><td><strong>@Loc["CoverageStart"]</strong></td><td>@_extracted.Insurance.CoverageStart</td></tr> }
                                    @if (_extracted.Insurance.CoverageEnd is not null) { <tr><td><strong>@Loc["CoverageEnd"]</strong></td><td>@_extracted.Insurance.CoverageEnd</td></tr> }
                                    @if (_extracted.Insurance.InsuredItem is not null) { <tr><td><strong>@Loc["Insured"]</strong></td><td>@_extracted.Insurance.InsuredItem</td></tr> }
                                </tbody>
                            </MudSimpleTable>
                        }
                        else if (_extracted.Contract is not null)
                        {
                            <MudSimpleTable Dense="true" Elevation="0">
                                <tbody>
                                    @if (_extracted.Contract.Counterparty is not null) { <tr><td><strong>@Loc["Counterparty"]</strong></td><td>@_extracted.Contract.Counterparty</td></tr> }
                                    @if (_extracted.Contract.Subject is not null) { <tr><td><strong>@Loc["Subject"]</strong></td><td>@_extracted.Contract.Subject</td></tr> }
                                    @if (_extracted.Contract.StartDate is not null) { <tr><td><strong>@Loc["Start"]</strong></td><td>@_extracted.Contract.StartDate</td></tr> }
                                    @if (_extracted.Contract.EndDate is not null) { <tr><td><strong>@Loc["End"]</strong></td><td>@_extracted.Contract.EndDate</td></tr> }
                                    @if (_extracted.Contract.NoticePeriod is not null) { <tr><td><strong>@Loc["Notice"]</strong></td><td>@_extracted.Contract.NoticePeriod</td></tr> }
                                    @if (_extracted.Contract.AutoRenewal.HasValue) { <tr><td><strong>@Loc["AutoRenew"]</strong></td><td>@(_extracted.Contract.AutoRenewal.Value ? Loc["Yes"] : Loc["No"])</td></tr> }
                                    @if (_extracted.Contract.RecurringAmount.HasValue) { <tr><td><strong>@Loc["Amount"]</strong></td><td>@_extracted.Contract.RecurringAmount (@_extracted.Contract.BillingFrequency)</td></tr> }
                                </tbody>
                            </MudSimpleTable>
                        }
                        else if (_extracted.Vehicle is not null)
                        {
                            <MudSimpleTable Dense="true" Elevation="0">
                                <tbody>
                                    @if (_extracted.Vehicle.LicensePlate is not null) { <tr><td><strong>@Loc["LicensePlate"]</strong></td><td>@_extracted.Vehicle.LicensePlate</td></tr> }
                                    @if (_extracted.Vehicle.Make is not null) { <tr><td><strong>@Loc["VehicleMake"]</strong></td><td>@_extracted.Vehicle.Make @_extracted.Vehicle.Model</td></tr> }
                                    @if (_extracted.Vehicle.ChassisNumber is not null) { <tr><td><strong>@Loc["ChassisNumber"]</strong></td><td>@_extracted.Vehicle.ChassisNumber</td></tr> }
                                    @if (_extracted.Vehicle.FirstRegistrationDate is not null) { <tr><td><strong>@Loc["FirstRegistered"]</strong></td><td>@_extracted.Vehicle.FirstRegistrationDate</td></tr> }
                                    @if (_extracted.Vehicle.InspectionDueDate is not null) { <tr><td><strong>@Loc["InspectionDue"]</strong></td><td>@_extracted.Vehicle.InspectionDueDate</td></tr> }
                                </tbody>
                            </MudSimpleTable>
                        }
                    }
                </MudCardContent>
            </MudCard>
        </MudItem>

        <MudItem xs="12" md="8">
            <MudCard Elevation="0" Style="border: 1px solid rgba(255,255,255,0.06);">
                <MudCardContent>
                    <MudTabs Elevation="0" ApplyEffectsToContainer="true" TabPanelsClass="pt-4" KeepPanelsAlive="true">
                        <MudTabPanel Text="@Loc["DocumentTab"]" Icon="@Icons.Material.Filled.Article">
                            @if (_isImageFile)
                            {
                                <MudImage Src="@_fileUrl" Alt="@_doc!.Title" Fluid="true" Class="rounded" />
                            }
                            else
                            {
                                <iframe src="@_fileUrl" title="@_doc!.Title"
                                        style="width: 100%; height: 75vh; border: 0; border-radius: 4px; background: #ffffff;"></iframe>
                            }
                        </MudTabPanel>
                        <MudTabPanel Text="@Loc["TextTab"]" Icon="@Icons.Material.Filled.Notes">
                            <div class="d-flex align-center justify-space-between mb-4">
                                <MudText Typo="Typo.subtitle1">@Loc["OcrContent"]</MudText>
                                <MudButton Variant="Variant.Outlined" Size="Size.Small" Color="Color.Secondary"
                                           OnClick="RunVisionOcrAsync" Disabled="_isRunningVision"
                                           StartIcon="@Icons.Material.Filled.RemoveRedEye">
                                    @(_isRunningVision ? Loc["RunningVisionOcr"] : Loc["VisionOcr"])
                                </MudButton>
                            </div>

                            @if (_documentContent is null)
                            {
                                <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
                            }
                            else if (string.IsNullOrWhiteSpace(_documentContent))
                            {
                                <MudAlert Severity="Severity.Info">@Loc["NoTextContentAvailable"]</MudAlert>
                            }
                            else
                            {
                                <MudText Typo="Typo.body2" Style="white-space: pre-wrap; font-family: monospace; opacity: 0.85;">@_documentContent</MudText>
                            }
                        </MudTabPanel>
                    </MudTabs>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>
}

@code {
    [Parameter] public int DocumentId { get; set; }

    [Inject] private PaperlessClient PaperlessClient { get; set; } = null!;
    [Inject] private OcrQualityChecker OcrQualityChecker { get; set; } = null!;
    [Inject] private VisionOcrService VisionOcrService { get; set; } = null!;
    [Inject] private StructuredExtractionService ExtractionService { get; set; } = null!;
    [Inject] private ExtractionCacheService ExtractionCache { get; set; } = null!;
    [Inject] private SuggestionStore SuggestionStore { get; set; } = null!;
    [Inject] private ReviewQueueService ReviewQueue { get; set; } = null!;
    [Inject] private IDialogService DialogService { get; set; } = null!;
    [Inject] private ISnackbar Snackbar { get; set; } = null!;
    [Inject] private NavigationManager Navigation { get; set; } = null!;

    private PaperlessDocument? _doc;
    private string? _documentContent;
    private string? _correspondentName;
    private string? _documentTypeName;
    private bool _isEditing;
    private bool _isSaving;
    private bool _isRerunning;
    private bool _forceVision;
    private (ClassificationResult? Classification, double Confidence, DateTime SuggestedAtUtc)? _suggestion;
    private string _editTitle = string.Empty;
    private string _editCorrespondent = string.Empty;
    private string _editDocumentType = string.Empty;
    private string _editTagsCsv = string.Empty;
    private List<string> _tagNames = [];
    private Dictionary<string, string> _tagLabels = new(StringComparer.OrdinalIgnoreCase);
    private bool _notFound;
    private bool _isRunningVision;
    private bool _isExtracting;
    private ExtractionResult? _extracted;
    private string? _paymentPayload;
    private string? _paymentQr;
    private bool _isImageFile;
    private string _fileUrl = string.Empty;

    private static readonly string[] ImageExtensions = [".jpg", ".jpeg", ".png", ".webp", ".gif"];

    protected override async Task OnInitializedAsync() => await LoadAsync();

    private async Task LoadAsync()
    {
        _doc = await PaperlessClient.GetDocumentAsync(DocumentId);
        if (_doc is null)
        {
            _notFound = true;
            return;
        }

        _documentContent = _doc.Content;

        var tagLookup = await PaperlessClient.GetTagLookupAsync();
        var correspondentLookup = await PaperlessClient.GetCorrespondentLookupAsync();
        var documentTypeLookup = await PaperlessClient.GetDocumentTypeLookupAsync();

        _tagNames = _doc.Tags
            .Where(tagLookup.ContainsKey)
            .Select(tagId => tagLookup[tagId])
            .ToList();

        if (_doc.CorrespondentId.HasValue && correspondentLookup.TryGetValue(_doc.CorrespondentId.Value, out var corrName))
            _correspondentName = corrName;

        if (_doc.DocumentTypeId.HasValue && documentTypeLookup.TryGetValue(_doc.DocumentTypeId.Value, out var typeName))
            _documentTypeName = typeName;

        _editTitle = _doc.Title;
        _editCorrespondent = _correspondentName ?? string.Empty;
        _editDocumentType = _documentTypeName ?? string.Empty;
        _editTagsCsv = string.Join(", ", _tagNames);

        _suggestion = await SuggestionStore.GetAsync(DocumentId);

        _tagLabels = await Taxonomy.GetDisplayMapAsync("tag", CultureInfo.CurrentUICulture.TwoLetterISOLanguageName);

        _extracted = await ExtractionCache.GetCachedAsync(DocumentId);
        ComputePaymentQr();

        var fileExtension = Path.GetExtension(_doc.OriginalFileName ?? string.Empty);
        _isImageFile = ImageExtensions.Contains(fileExtension, StringComparer.OrdinalIgnoreCase);
        // Root-relative so the iframe inherits the page scheme/host — an absolute
        // URL built from BaseUri renders http:// inside an https:// page and the
        // browser blocks it as mixed content
        _fileUrl = _isImageFile
            ? $"/documents/{DocumentId}/file?original=true"
            : $"/documents/{DocumentId}/file";
    }

    private async Task SaveEditAsync()
    {
        _isSaving = true;
        try
        {
            // Same human-decides-the-metadata path as the review queue: the applier
            // resolves or creates names and preserves nothing the human removed
            var finalDecision = new ClassificationResult
            {
                SuggestedTitle = _editTitle,
                Correspondent = string.IsNullOrWhiteSpace(_editCorrespondent) ? null : _editCorrespondent,
                DocumentType = string.IsNullOrWhiteSpace(_editDocumentType) ? null : _editDocumentType,
                Tags = _editTagsCsv.Split(',', StringSplitOptions.TrimEntries | StringSplitOptions.RemoveEmptyEntries).ToList(),
                Confidence = 1.0
            };

            var outcome = await ReviewQueue.ApplyAsync(DocumentId, finalDecision);
            if (outcome.Applied)
            {
                Snackbar.Add(Loc["DocumentUpdated"].Value, Severity.Success);
                _isEditing = false;
                await LoadAsync();
            }
            else
            {
                Snackbar.Add(Loc["FailedToApply", outcome.Error ?? string.Empty].Value, Severity.Error);
            }
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task ApplySuggestionAsync()
    {
        if (_suggestion?.Classification is not { } parked) return;

        _isSaving = true;
        try
        {
            var outcome = await ReviewQueue.ApplyAsync(DocumentId, parked);
            if (outcome.Applied)
            {
                Snackbar.Add(Loc["FiledAs", outcome.NewTitle ?? string.Empty].Value, Severity.Success);
                await LoadAsync();
            }
            else
            {
                Snackbar.Add(Loc["FailedToApply", outcome.Error ?? string.Empty].Value, Severity.Error);
            }
        }
        finally
        {
            _isSaving = false;
        }
    }

    private void EditFromSuggestion()
    {
        if (_suggestion?.Classification is not { } parked) return;

        _editTitle = string.IsNullOrWhiteSpace(parked.SuggestedTitle) ? _doc!.Title : parked.SuggestedTitle;
        _editCorrespondent = parked.Correspondent ?? string.Empty;
        _editDocumentType = parked.DocumentType ?? string.Empty;
        _editTagsCsv = string.Join(", ", parked.Tags);
        _isEditing = true;
    }

    private async Task RerunClassificationAsync()
    {
        _isRerunning = true;
        try
        {
            var (entry, rerunError) = await ReviewQueue.ReclassifyAsync(DocumentId, _forceVision);
            if (entry is not null)
            {
                Snackbar.Add(Loc["Reclassified"].Value, Severity.Success);
                await LoadAsync();
            }
            else
            {
                Snackbar.Add(Loc["RerunFailed", rerunError ?? string.Empty].Value, Severity.Error);
            }
        }
        finally
        {
            _isRerunning = false;
        }
    }

    private async Task DeleteAsync()
    {
        var confirmed = await DialogService.ShowMessageBoxAsync(
            Loc["DeleteConfirmTitle"].Value,
            Loc["DeleteConfirmText", _doc!.Title].Value,
            yesText: Loc["Delete"].Value,
            cancelText: Loc["Cancel"].Value);
        if (confirmed != true)
            return;

        _isSaving = true;
        try
        {
            var deleted = await PaperlessClient.DeleteDocumentAsync(DocumentId);
            if (deleted)
            {
                // Clean our cache rows too, or the extraction haunts the expiring list
                await ExtractionCache.DeleteAsync(DocumentId);
                await SuggestionStore.DeleteAsync(DocumentId);
                Snackbar.Add(Loc["DocumentDeleted"].Value, Severity.Success);
                Navigation.NavigateTo("/documents");
            }
            else
            {
                Snackbar.Add(Loc["DeleteFailed"].Value, Severity.Error);
            }
        }
        finally
        {
            _isSaving = false;
        }
    }

    private async Task RunVisionOcrAsync()
    {
        if (!VisionOcrService.IsEnabled)
        {
            Snackbar.Add(Loc["VisionOcrNotConfigured"].Value, Severity.Warning);
            return;
        }

        _isRunningVision = true;
        StateHasChanged();

        var originalBytes = await PaperlessClient.DownloadOriginalAsync(DocumentId);
        if (originalBytes is null)
        {
            Snackbar.Add(Loc["FailedToDownloadOriginal"].Value, Severity.Error);
            _isRunningVision = false;
            return;
        }

        var visionText = await VisionOcrService.ExtractTextFromImageAsync(originalBytes);
        if (visionText is not null)
        {
            _documentContent = visionText;
            Snackbar.Add(Loc["VisionOcrExtractedCharacters", visionText.Length].Value, Severity.Success);
        }
        else
        {
            Snackbar.Add(Loc["VisionOcrReturnedNoText"].Value, Severity.Warning);
        }

        _isRunningVision = false;
    }

    private async Task RunExtractionAsync()
    {
        if (!ExtractionService.IsEnabled)
        {
            Snackbar.Add(Loc["StructuredExtractionNotConfigured"].Value, Severity.Warning);
            return;
        }

        _isExtracting = true;
        StateHasChanged();

        // Runs through the cache so results survive page refreshes
        _extracted = await ExtractionCache.GetOrExtractAsync(DocumentId, forceRefresh: true);
        ComputePaymentQr();

        if (_extracted is not null)
            Snackbar.Add(Loc["ClassifiedAs", _extracted.Category, $"{_extracted.Confidence:P0}"].Value, Severity.Success);
        else
            Snackbar.Add(Loc["ExtractionFailedCheckLogs"].Value, Severity.Error);

        _isExtracting = false;
    }

    private string TagLabel(string canonical) => _tagLabels.TryGetValue(canonical, out var label) ? label : canonical;

    private void ComputePaymentQr()
    {
        _paymentPayload = _extracted?.Invoice is not null ? EpcPayment.BuildForInvoice(_extracted.Invoice, _correspondentName) : null;
        _paymentQr = _paymentPayload is not null ? PaymentQrRenderer.ToDataUri(_paymentPayload) : null;
    }
}
